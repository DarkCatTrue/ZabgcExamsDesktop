<Page x:Class="ZabgcExamsDesktop.MVVM.View.Pages.ResultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ZabgcExamsDesktop.MVVM.View.Pages"
    mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="ResultPage"
      Background="#323a47">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        
        <Button Grid.Row="1" Grid.ColumnSpan="6" Content="Вернуться назад" Command="{Binding BackToSearchCommand}"/>
        
        <ComboBox x:Name="DepartmentComboBox" Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Department}" SelectedItem="{Binding SelectedDepartment}" DisplayMemberPath="NameOfDepartment"/>

        <Button Content="+" Grid.Column="2" Grid.Row="2" Command="{Binding SelectionGroupsCommand}" Width="40" Height="30" Margin="340 0 0 0"/>
        
        <TextBox Foreground="White" IsReadOnly="True" Text="{Binding GroupsText}" Grid.Row="2" Grid.Column="2" Width="340" HorizontalAlignment="Left"/>

        <!--<ListBox x:Name="GroupsListBox" 
         Grid.Row="2"
         SelectionMode="Multiple"
         Grid.Column="2" 
         ItemsSource="{Binding FilteredGroup}"
         Height="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding NameOfGroup}"
                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Margin="2"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>-->
        
        <ComboBox 
            Grid.Row="2"
            Grid.Column="0"
            SelectedItem="{Binding SelectedResult}"
            ItemsSource="{Binding ResultItems}">
        </ComboBox>
        
        <Button x:Name="SearchBtn" 
                Grid.Row="2" 
                Grid.Column="3"
                Content="Поиск"
                Command="{Binding SearchCommand}"
                >
        </Button>

        <Button 
            Grid.Row="2"
            Grid.Column="4" 
            Content="Сохранить в PDF" 
            Command="{Binding SavePdfCommand}">
        </Button>

        <DataGrid
            Grid.Row="3" 
            Grid.ColumnSpan="5"
            ItemsSource="{Binding SearchResult}"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            IsReadOnly="True">

            <DataGrid.Columns>


                <DataGridTextColumn Width="*" Header="Отделение" Binding="{Binding DepartmentName}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>


                <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}"/>

                <DataGridTextColumn Header="Консультация/Экзамен" Binding="{Binding TypeOfLessonName}"/>

                <DataGridTextColumn Header="Тип экзамена" Binding="{Binding TypeOfExamName}"/>

                <DataGridTextColumn Width="*" Header="Дисциплина" Binding="{Binding DisciplineName}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>


                <DataGridTextColumn Width="*" Header="Преподаватели" Binding="{Binding TeachersDisplay}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Аудитория" Binding="{Binding AudienceNumber}"/>

                <DataGridTextColumn Header="Дата/время" 
                 Binding="{Binding DateEvent, StringFormat='{} {0:dd.MM.yyyy HH:mm}'}"/>
                
                <DataGridTemplateColumn Header="Действия" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource DeleteButtonStyle}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid> 
    </Grid>
</Page>
