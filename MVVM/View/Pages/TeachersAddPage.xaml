<Page x:Class="ZabgcExamsDesktop.MVVM.View.Pages.TeachersAddPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ZabgcExamsDesktop.MVVM.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="310" d:DesignWidth="580"
      Background="#323a47"
      Title="Добавление членов ЭК">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="100"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="1" Text="Доступные преподаватели" Foreground="White" TextAlignment="Center"/>
        <ListBox Grid.Row="2" Grid.RowSpan="2"  ItemsSource="{Binding Teacher}" VerticalAlignment="Top" SelectedItem="{Binding SelectedAvailableTeacher}" DisplayMemberPath="FullName"/>

        <TextBlock Grid.Row="1" Grid.Column="2" Text="Выбранные преподаватели" Foreground="White" TextAlignment="Center"/>
        <ListBox Grid.Row="2" Grid.RowSpan="2" Grid.Column="2" ScrollViewer.VerticalScrollBarVisibility="Visible" ItemsSource="{Binding SelectedTeachers}" SelectedItem="{Binding SelectedTeacherToRemove}" DisplayMemberPath="FullName"/>

        <StackPanel Grid.Column="1" Grid.Row="2"  VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button Content="Добавить" Command="{Binding AddTeacherCommand}"/>
            <Button Content="Удалить" Margin="0 10 0 0" Command="{Binding RemoveTeacherCommand}"/>
        </StackPanel>

        <Button Grid.Row="3" Width="115" Grid.Column="1" Content="Сохранить" Command="{Binding SaveAndExitCommand}"/>

    </Grid>
</Page>
