<Page x:Class="ZabgcExamsDesktop.MVVM.View.Pages.SelectionGroupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ZabgcExamsDesktop.MVVM.View.Pages"
      mc:Ignorable="d" 
       d:DesignHeight="340" d:DesignWidth="580"
  Background="#323a47"
  Title="Добавление членов ЭК">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="100"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="1" Text="Отделение" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White"/>
        <ComboBox Grid.Row="1" Grid.ColumnSpan="3"  ItemsSource="{Binding Department}" SelectedItem="{Binding SelectedDepartment}" DisplayMemberPath="NameOfDepartment"/>
        
        <TextBlock Grid.Row="2" Text="Доступные группы" Foreground="White" TextAlignment="Center"/>
        <ListBox Grid.Row="3" Grid.RowSpan="2"  ItemsSource="{Binding FilteredGroup}" VerticalAlignment="Top" SelectedItem="{Binding SelectedAvailableGroup}" DisplayMemberPath="NameOfGroup"/>

        <TextBlock Grid.Row="2" Grid.Column="2" Text="Выбранные группы" Foreground="White" TextAlignment="Center"/>
        
        <ListBox Grid.Row="3" Grid.RowSpan="2" Grid.Column="2" ScrollViewer.VerticalScrollBarVisibility="Visible" ItemsSource="{Binding SelectedGroups}" SelectedItem="{Binding SelectedGroupToRemove}" DisplayMemberPath="NameOfGroup"/>

        <StackPanel Grid.Column="1" Grid.Row="3"  VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button Content="Добавить" Command="{Binding AddGroupCommand}"/>
            <Button Content="Удалить" Margin="0 10 0 0" Command="{Binding RemoveGroupCommand}"/>
        </StackPanel>

        <Button Grid.Row="4" Width="115" Grid.Column="1" Content="Сохранить" Command="{Binding SaveAndExitCommand}"/>

    </Grid>
</Page>
