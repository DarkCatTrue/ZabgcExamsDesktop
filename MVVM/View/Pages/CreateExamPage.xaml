<Page x:Class="ZabgcExamsDesktop.MVVM.View.Pages.ExamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:ZabgcExamsDesktop.MVVM.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="350"
      Title="ExamPage"
      Background="#323a47">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        
        <TextBlock Grid.Row="1" Text="Вид занятия" VerticalAlignment="Center" HorizontalAlignment="Center"  Style="{StaticResource GlobalTextBlockStyle}"/>
        <TextBlock Grid.Row="2" Text="Вид экзамена" VerticalAlignment="Center" HorizontalAlignment="Center"  Style="{StaticResource GlobalTextBlockStyle}"/>
        <TextBlock Grid.Row="3" Text="Отделение" VerticalAlignment="Center" HorizontalAlignment="Center"  Style="{StaticResource GlobalTextBlockStyle}"/>
        <TextBlock Grid.Row="4" Text="Группа" VerticalAlignment="Center" HorizontalAlignment="Center"  Style="{StaticResource GlobalTextBlockStyle}"/>
        <TextBlock Grid.Row="5" Text="Аудитория" VerticalAlignment="Center" HorizontalAlignment="Center"  Style="{StaticResource GlobalTextBlockStyle}"/>
        <TextBlock Grid.Row="6" Text="Дисциплина" VerticalAlignment="Center" HorizontalAlignment="Center"  Style="{StaticResource GlobalTextBlockStyle}"/>
        <TextBlock Grid.Row="7" Text="Члены ЭК" VerticalAlignment="Center" HorizontalAlignment="Center"  Style="{StaticResource GlobalTextBlockStyle}"/>
        <TextBlock Grid.Row="8" Text="Дата/Время" VerticalAlignment="Center" HorizontalAlignment="Center"  Style="{StaticResource GlobalTextBlockStyle}"/>
        
        <ComboBox Grid.Column="1" Grid.Row="1" Name="TypeLesson" ItemsSource="{Binding Lesson}" DisplayMemberPath="NameOfTypeOfLesson" SelectedItem="{Binding SelectedLesson}" Height="30"/>
        <ComboBox Grid.Column="1" Grid.Row="2" Name="TypeExam" ItemsSource="{Binding TypeOfExam}" DisplayMemberPath="NameOfTypeOfExam" SelectedItem="{Binding SelectedTypeOfExam}" Height="30"/>
        <ComboBox Grid.Column="1" Grid.Row="3" Name="Department" ItemsSource="{Binding Department}" DisplayMemberPath="NameOfDepartment" SelectedItem="{Binding SelectedDepartment}" Height="30"/>
        <ComboBox Grid.Column="1" Grid.Row="4" Name="Group" Height="30" ItemsSource="{Binding Group}" Text="{Binding SearchGroupsText}" DisplayMemberPath="NameOfGroup" SelectedItem="{Binding SelectedGroup}" IsTextSearchEnabled="False" IsEditable="True"/>
        <ComboBox Grid.Column="1" Grid.Row="5" Name="Audience" Height="30" ItemsSource="{Binding Audience}" Text="{Binding SearchAudienceText}" DisplayMemberPath="NumberAudience" SelectedItem="{Binding SelectedAudience}" IsTextSearchEnabled="False" IsEditable="True"/>
        <ComboBox Grid.Column="1" Grid.Row="6" Name="Discipline" Height="30" ItemsSource="{Binding Discipline}" Text="{Binding SearchDisciplineText}" DisplayMemberPath="NameDiscipline" SelectedValuePath="IdDiscipline" SelectedItem="{Binding SelectedDiscipline}" IsTextSearchEnabled="False" IsEditable="True"/>

        <Button Content="+" Grid.Column="1" Grid.Row="7" Command="{Binding SelectionTeachersCommand}" Height="25" Width="40" HorizontalAlignment="Right"/>
        <TextBox Foreground="White" Grid.Column="1" Grid.Row="7" Text="{Binding TeachersText}" IsReadOnly="True" Margin="0 0 40 0"/>


        <DatePicker Grid.Column="1" Grid.Row="8" SelectedDate="{Binding SelectedDate}" Name="DateEvent" Language="RU" Foreground="White" Width="100" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <md:TimePicker Grid.Column="1" Text="{Binding SelectedTime}" Grid.Row="8" Name="TimeEvent" Foreground="White" Is24Hours="True" Width="60" SelectedTimeFormat="Long" VerticalAlignment="Center" HorizontalAlignment="Right" />
        <Button Content="Добавить запись" Command="{Binding SaveExamsCommand}" Grid.Row="10" Grid.ColumnSpan="2" Height="Auto" VerticalAlignment="Stretch" Cursor="Hand"/>
    </Grid>
</Page>
