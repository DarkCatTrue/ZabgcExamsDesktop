<Page x:Class="ZabgcExamsDesktop.MVVM.View.Pages.SearchExamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ZabgcExamsDesktop.MVVM.View.Pages" 
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="SearchExamPage"
      Background="#323a47"
      >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        
        <Button Name="EditDataBaseBtn" Grid.ColumnSpan="2" Grid.Row="1" Content="Редактирование базы данных" Command="{Binding EditDataBaseCommand}"/>
        <Button Name="CreateSchedule" Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="2" Command="{Binding CreateExamCommand}" Content="Добавить экзамен"/>
        <Button Name="CreateResult" Grid.Column="4" Grid.ColumnSpan="2" Grid.Row="1" Command="{Binding GoToResultCommand}" Content="Печать отчёта"/>

        <!-- Отделения -->
        <ComboBox 
          Grid.Row="3"
          ItemsSource="{Binding FilteredDepartments}"
          DisplayMemberPath="NameOfDepartment"
          SelectedItem="{Binding SelectedDepartment}"
          IsEditable="True"
          IsTextSearchEnabled="False"
          Text="{Binding DepartmentSearchText, UpdateSourceTrigger=PropertyChanged}"/>

        <ComboBox 
          Grid.Row="3"
          Grid.Column="1"
          ItemsSource="{Binding FilteredGroups}"
          DisplayMemberPath="NameOfGroup"
          SelectedItem="{Binding SelectedGroup}"
          IsEditable="True"
          IsTextSearchEnabled="False"
          Text="{Binding GroupSearchText, UpdateSourceTrigger=PropertyChanged}"/>

        <ComboBox 
          Grid.Row="3" Grid.Column="2"
          ItemsSource="{Binding FilteredTeachers}"
          DisplayMemberPath="FullName"
          SelectedItem="{Binding SelectedTeacher}"
          IsEditable="True"
          IsTextSearchEnabled="False"
          Text="{Binding TeacherSearchText, UpdateSourceTrigger=PropertyChanged}"/>

        <ComboBox 
          Grid.Row="3" Grid.Column="3"
          ItemsSource="{Binding FilteredAudiences}"
          DisplayMemberPath="NumberAudience"
          SelectedItem="{Binding SelectedAudience}"
          IsEditable="True"
          IsTextSearchEnabled="False"
          Text="{Binding AudienceSearchText, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Text="Отделение" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource GlobalTextBlockStyle}" />
        <TextBlock Text="Группа" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource GlobalTextBlockStyle}" />
        <TextBlock Text="Преподаватель" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource GlobalTextBlockStyle}" />
        <TextBlock Text="Аудитория" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource GlobalTextBlockStyle}" />

        <Button Grid.Column="4" Grid.Row="2" Margin="2 -2 2 0" Content="Поиск" Command="{Binding SearchCommand}"/>
        <Button Grid.Column="5" Grid.Row="2" Margin="2 -2 2 0"  Content="Очистить поиск" Command="{Binding ClearSearchCommand}"/>
        <Button Grid.Column="4" Grid.ColumnSpan="2" Grid.Row="3" Content="Удалить неактуальные экзамены" Command="{Binding DeleteOldExamsCommand}"/>

        <DataGrid x:Name="ScheduleGrid" Grid.ColumnSpan="6" Grid.Row="4" 
          ItemsSource="{Binding SearchResults}"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True">

            <DataGrid.Columns>


                <DataGridTextColumn Width="*" Header="Отделение" Binding="{Binding DepartmentName}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>


                <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}"/>

                <DataGridTextColumn Header="Консультация/Экзамен" Binding="{Binding TypeOfLessonName}"/>

                <DataGridTextColumn Header="Тип экзамена" Binding="{Binding TypeOfExamName}"/>

                <DataGridTextColumn Width="*" Header="Дисциплина" Binding="{Binding DisciplineName}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>


                <DataGridTextColumn Width="*" Header="Преподаватели" Binding="{Binding TeachersDisplay}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Аудитория" Binding="{Binding AudienceNumber}"/>
                
                <DataGridTextColumn Header="Дата/время" 
                       Binding="{Binding DateEvent, StringFormat='{} {0:dd.MM.yyyy HH:mm}'}"/>
                <DataGridTemplateColumn Header="Действия" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource DeleteButtonStyle}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
